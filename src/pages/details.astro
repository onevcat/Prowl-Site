---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";

const features = [
  {
    id: "custom-actions",
    title: "Custom Actions",
    tagline: "Your repo, your rules.",
    description:
      "Define up to 3 custom command buttons per repository — each with its own icon, title, and optional keyboard shortcut. Execute as a shell script or inject directly into the terminal. One click to run your most-used workflows.",
    image: "/images/feature-custom-actions.png",
    details: [
      "Per-repo command buttons in the toolbar",
      "Shell Script or Terminal Input execution modes",
      "Custom keyboard shortcuts with modifier keys",
      "SF Symbol icons for visual distinction",
    ],
  },
  {
    id: "diff-view",
    title: "Diff View",
    tagline: "See what changed, instantly.",
    description:
      "A built-in diff window with a file tree sidebar. Switch between split and unified views to review worktree changes without leaving your terminal. Preloads all file contents for instant file switching.",
    image: "/images/feature-diff-view.png",
    details: [
      "File tree sidebar with toggle",
      "Split view and unified diff modes",
      "Instant file switching with content preloading",
      "Keyboard-driven navigation",
    ],
  },
  {
    id: "canvas",
    title: "Canvas",
    tagline: "All your agents, one view.",
    description:
      "A free-form canvas that displays every open tab as a draggable, resizable card. Pinch to zoom, scroll to pan — see all your coding agents working in parallel at a glance.",
    image: "/images/feature-canvas.png",
    details: [
      "Draggable and resizable tab cards",
      "Pinch-to-zoom with cursor anchoring",
      "Balanced grid layout with auto-organize",
      "Full split pane rendering per card",
    ],
  },
];
---

<Layout title="Prowl — Details">
  <Nav active="details" />

  <main class="details-page">
    <section class="details-hero">
      <h1 class="page-title">What makes Prowl different</h1>
      <p class="page-subtitle">
        Features forked with intent — built for a terminal-first, agent-driven
        workflow.
      </p>
    </section>

    <!-- Feature 1: Custom Actions -->
    <section class="feature-section" id="custom-actions">
      <div class="feature-content">
        <div class="feature-header">
          <span class="feature-number">01</span>
          <h2 class="feature-title">Custom Actions</h2>
        </div>
        <p class="feature-tagline">Your repo, your rules.</p>
        <ul class="feature-details">
          <li>Up to 3 command buttons per repo</li>
          <li>Shell Script or Terminal Input execution</li>
          <li>Custom keyboard shortcuts with modifiers</li>
        </ul>
        <div class="feature-shortcut">
          <kbd>&#8984;</kbd> + custom key per action
        </div>
      </div>
      <div class="feature-image-wrapper">
        <div class="image-placeholder">
          <img src="/images/feature-custom-actions.png" alt="Custom Actions screenshot" class="feature-image" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="placeholder-fallback">
            <span>Screenshot coming soon</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Paw divider -->
    <div class="paw-divider" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
        <ellipse cx="6.5" cy="3.5" rx="2" ry="2.4" />
        <ellipse cx="13.5" cy="3.5" rx="2" ry="2.4" />
        <ellipse cx="3.2" cy="8.8" rx="1.7" ry="2.1" />
        <ellipse cx="16.8" cy="8.8" rx="1.7" ry="2.1" />
        <path d="M10 18.5c-3.2 0-5.8-2.2-5.8-4.5 0-2 1.6-3.5 3.2-3.5.9 0 1.4.6 2.6.6s1.7-.6 2.6-.6c1.6 0 3.2 1.5 3.2 3.5 0 2.3-2.6 4.5-5.8 4.5z" />
      </svg>
    </div>

    <!-- Feature 2: Diff View (inset card) -->
    <section class="feature-section feature-inset reverse" id="diff-view">
      <div class="feature-content">
        <div class="feature-header">
          <span class="feature-number">02</span>
          <h2 class="feature-title">Diff View</h2>
        </div>
        <p class="feature-tagline">See what changed, instantly.</p>
        <ul class="feature-details">
          <li>One-key open with <kbd>&#8984;]</kbd></li>
          <li>Split view and unified diff modes</li>
          <li>File tree sidebar + instant switching</li>
        </ul>
      </div>
      <div class="feature-image-wrapper">
        <div class="image-placeholder">
          <img src="/images/feature-diff-view.png" alt="Diff View screenshot" class="feature-image" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="placeholder-fallback">
            <span>Screenshot coming soon</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Paw divider -->
    <div class="paw-divider" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
        <ellipse cx="6.5" cy="3.5" rx="2" ry="2.4" />
        <ellipse cx="13.5" cy="3.5" rx="2" ry="2.4" />
        <ellipse cx="3.2" cy="8.8" rx="1.7" ry="2.1" />
        <ellipse cx="16.8" cy="8.8" rx="1.7" ry="2.1" />
        <path d="M10 18.5c-3.2 0-5.8-2.2-5.8-4.5 0-2 1.6-3.5 3.2-3.5.9 0 1.4.6 2.6.6s1.7-.6 2.6-.6c1.6 0 3.2 1.5 3.2 3.5 0 2.3-2.6 4.5-5.8 4.5z" />
      </svg>
    </div>

    <!-- Feature 3: Canvas (highlight) -->
    <section class="feature-section feature-highlight" id="canvas">
      <div class="feature-content">
        <div class="feature-header">
          <span class="feature-number">03</span>
          <h2 class="feature-title feature-title-lg">Canvas</h2>
        </div>
        <p class="feature-tagline">All your agents, one view.</p>
        <ul class="feature-details">
          <li>Every tab as a draggable, resizable card</li>
          <li>Pinch-to-zoom with cursor anchoring</li>
          <li>Auto-organize with balanced grid layout</li>
        </ul>
      </div>
      <div class="feature-image-wrapper">
        <div class="image-placeholder">
          <img src="/images/feature-canvas.png" alt="Canvas screenshot" class="feature-image" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="placeholder-fallback">
            <span>Screenshot coming soon</span>
          </div>
        </div>
      </div>
    </section>

    <p class="upstream-note">
      …and everything else great from <a href="https://supacode.sh/" target="_blank" rel="noopener">Supacode</a>.
    </p>

    <section class="cta-section">
      <p class="cta-text">Start prowling.</p>
      <div class="cta-group">
        <a
          href="https://github.com/onevcat/supacode/releases/latest"
          class="btn btn-primary"
          target="_blank"
          rel="noopener"
        >
          Download Prowl
        </a>
        <a
          href="https://github.com/onevcat/supacode"
          class="btn btn-secondary"
          target="_blank"
          rel="noopener"
        >
          View on GitHub
        </a>
      </div>
    </section>

    <footer class="footer">
      <p>
        Built by <a
          href="https://github.com/onevcat"
          target="_blank"
          rel="noopener">onevcat</a
        > · A fork of <a
          href="https://supacode.sh/"
          target="_blank"
          rel="noopener">Supacode</a
        >
      </p>
    </footer>
    <!-- Lightbox modal -->
    <div class="lightbox" id="lightbox">
      <img class="lightbox-img" id="lightbox-img" alt="Enlarged screenshot" />
    </div>
  </main>
</Layout>

<script>
  const lightbox = document.getElementById("lightbox")!;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;

  document.querySelectorAll(".feature-image").forEach((img) => {
    img.addEventListener("click", () => {
      lightboxImg.src = (img as HTMLImageElement).src;
      lightbox.classList.add("open");
    });
  });

  lightbox.addEventListener("click", () => {
    lightbox.classList.remove("open");
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") lightbox.classList.remove("open");
  });
</script>

<style>
  .details-page {
    padding-top: 4rem;
  }

  /* Hero */
  .details-hero {
    text-align: center;
    padding: 6rem 2rem 4rem;
  }

  .page-title {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Feature sections */
  .feature-section {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 3rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .feature-section.reverse {
    grid-template-columns: 3fr 2fr;
  }

  .feature-section.reverse .feature-content {
    order: 2;
  }

  .feature-section.reverse .feature-image-wrapper {
    order: 1;
  }

  /* Highlight variation (Canvas — the star) */
  .feature-highlight {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .feature-title-lg {
    font-size: 2.25rem;
  }

  /* Keyboard shortcut badge */
  .feature-shortcut {
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .feature-shortcut kbd,
  .feature-details kbd {
    display: inline-block;
    padding: 1px 6px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    line-height: 1.4;
  }

  /* Paw print divider */
  .paw-divider {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0;
    color: rgba(90, 228, 192, 0.15);
  }

  .feature-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .feature-number {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-dim);
    font-weight: 500;
  }

  .feature-title {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .feature-tagline {
    font-size: 1.1rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .feature-description {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .feature-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature-details li {
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding-left: 1.25rem;
    position: relative;
  }

  .feature-details li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--accent-dim);
    font-weight: 700;
  }

  /* Image area */
  .feature-image-wrapper {
    position: relative;
  }

  .image-placeholder {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
  }

  .feature-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    cursor: zoom-in;
    transition: opacity 0.2s;
  }

  .feature-image:hover {
    opacity: 0.85;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
    cursor: zoom-out;
  }

  .lightbox.open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    transform: scale(0.95);
    transition: transform 0.25s;
  }

  .lightbox.open .lightbox-img {
    transform: scale(1);
  }

  .placeholder-fallback {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    position: absolute;
    inset: 0;
    color: var(--text-muted);
  }

  .placeholder-fallback span {
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }

  /* Upstream note */
  .upstream-note {
    text-align: center;
    padding: 2rem 2rem 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .upstream-note a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: rgba(136, 153, 180, 0.3);
    text-underline-offset: 2px;
  }

  .upstream-note a:hover {
    color: var(--accent);
    opacity: 1;
  }

  /* Bottom CTA */
  .cta-section {
    text-align: center;
    padding: 5rem 2rem;
    border-top: 1px solid var(--border);
    margin-top: 2rem;
  }

  .cta-text {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-mono);
    transition: all 0.15s;
    cursor: pointer;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg-primary);
    border-color: var(--accent);
  }

  .btn-primary:hover {
    opacity: 1;
    background: #6ef0cc;
    border-color: #6ef0cc;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(90, 228, 192, 0.25);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-secondary);
    border-color: rgba(136, 153, 180, 0.25);
  }

  .btn-secondary:hover {
    opacity: 1;
    color: var(--text-primary);
    border-color: rgba(136, 153, 180, 0.5);
    transform: translateY(-1px);
  }

  /* Footer */
  .footer {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    border-top: 1px solid var(--border);
  }

  .footer a {
    color: var(--text-secondary);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .feature-section {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 3rem 1.5rem;
    }

    .feature-section.reverse .feature-content,
    .feature-section.reverse .feature-image-wrapper {
      order: unset;
    }

    .page-title {
      font-size: 2rem;
    }

    .feature-title {
      font-size: 1.4rem;
    }

    .feature-title-lg {
      font-size: 1.6rem;
    }

    .cta-group {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
