---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout title="Prowl — Quiet paws. Sharp claws.">
  <Nav active="home" />

  <main class="hero">
    <!-- Background decorations -->
    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <div class="hero-content">
      <div class="icon-wrapper">
        <div class="icon-glow"></div>
        <img
          src="/images/prowl-icon.png"
          alt="Prowl App Icon"
          class="app-icon"
        />
      </div>

      <h1 class="title">Prowl</h1>
      <p class="slogan">Quiet paws. Sharp claws.</p>
      <p class="subtitle">
        An integrated terminal environment, sharpened for coding agents.
      </p>

      <div class="cta-group">
        <a
          href="https://github.com/onevcat/supacode/releases/latest"
          class="btn btn-primary"
          target="_blank"
          rel="noopener"
        >
          <svg
            class="btn-icon"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12v1.5h10V12" />
          </svg>
          Download
        </a>
        <a href="/details" class="btn btn-secondary">
          Details
          <svg
            class="btn-icon"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M6 3l5 5-5 5" />
          </svg>
        </a>
      </div>

      <p class="fork-note">
        A personal fork of <a
          href="https://supacode.sh/"
          target="_blank"
          rel="noopener">Supacode</a
        >, crafted for daily use.
      </p>
    </div>

    <!-- Decorative paw prints -->
    <div class="paw-prints" aria-hidden="true">
      <svg class="paw paw-1" viewBox="0 0 24 24" fill="currentColor">
        <ellipse cx="8" cy="6" rx="2.5" ry="3" />
        <ellipse cx="16" cy="6" rx="2.5" ry="3" />
        <ellipse cx="4" cy="13" rx="2" ry="2.5" />
        <ellipse cx="20" cy="13" rx="2" ry="2.5" />
        <path
          d="M12 22c-4 0-7-3-7-6s2-5 4-5c1.5 0 2 1 3 1s1.5-1 3-1c2 0 4 2 4 5s-3 6-7 6z"
        />
      </svg>
      <svg class="paw paw-2" viewBox="0 0 24 24" fill="currentColor">
        <ellipse cx="8" cy="6" rx="2.5" ry="3" />
        <ellipse cx="16" cy="6" rx="2.5" ry="3" />
        <ellipse cx="4" cy="13" rx="2" ry="2.5" />
        <ellipse cx="20" cy="13" rx="2" ry="2.5" />
        <path
          d="M12 22c-4 0-7-3-7-6s2-5 4-5c1.5 0 2 1 3 1s1.5-1 3-1c2 0 4 2 4 5s-3 6-7 6z"
        />
      </svg>
      <svg class="paw paw-3" viewBox="0 0 24 24" fill="currentColor">
        <ellipse cx="8" cy="6" rx="2.5" ry="3" />
        <ellipse cx="16" cy="6" rx="2.5" ry="3" />
        <ellipse cx="4" cy="13" rx="2" ry="2.5" />
        <ellipse cx="20" cy="13" rx="2" ry="2.5" />
        <path
          d="M12 22c-4 0-7-3-7-6s2-5 4-5c1.5 0 2 1 3 1s1.5-1 3-1c2 0 4 2 4 5s-3 6-7 6z"
        />
      </svg>
    </div>
  </main>
</Layout>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    overflow: hidden;
  }

  /* Background glow effect */
  .bg-glow {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(90, 228, 192, 0.08) 0%,
      rgba(90, 228, 192, 0.02) 40%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Subtle grid pattern */
  .bg-grid {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
        rgba(90, 228, 192, 0.03) 1px,
        transparent 1px
      ),
      linear-gradient(90deg, rgba(90, 228, 192, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(
      ellipse 50% 50% at 50% 50%,
      black 20%,
      transparent 100%
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
    z-index: 1;
  }

  /* Icon with glow */
  .icon-wrapper {
    position: relative;
    margin-bottom: 2rem;
  }

  .icon-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(
      circle,
      rgba(90, 228, 192, 0.2) 0%,
      transparent 70%
    );
    border-radius: 50%;
    filter: blur(20px);
  }

  .app-icon {
    position: relative;
    width: 128px;
    height: 128px;
    border-radius: 28px;
    box-shadow:
      0 0 0 1px rgba(90, 228, 192, 0.15),
      0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .title {
    font-family: var(--font-mono);
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    background: linear-gradient(
      135deg,
      var(--text-primary) 0%,
      var(--accent) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .slogan {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 420px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: var(--font-sans);
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-icon {
    width: 16px;
    height: 16px;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg-primary);
    box-shadow:
      0 0 0 1px rgba(90, 228, 192, 0.3),
      0 4px 20px rgba(90, 228, 192, 0.2);
  }

  .btn-primary:hover {
    opacity: 1;
    background: #6ef0cc;
    box-shadow:
      0 0 0 1px rgba(90, 228, 192, 0.5),
      0 8px 30px rgba(90, 228, 192, 0.3);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: var(--bg-card);
    color: var(--text-primary);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    opacity: 1;
    border-color: rgba(90, 228, 192, 0.3);
    background: var(--bg-secondary);
    transform: translateY(-1px);
  }

  .fork-note {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .fork-note a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: rgba(136, 153, 180, 0.3);
    text-underline-offset: 2px;
  }

  .fork-note a:hover {
    color: var(--accent);
    opacity: 1;
  }

  /* Decorative paw prints */
  .paw-prints {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .paw {
    position: absolute;
    color: rgba(90, 228, 192, 0.04);
  }

  .paw-1 {
    width: 40px;
    top: 20%;
    left: 15%;
    transform: rotate(-30deg);
  }

  .paw-2 {
    width: 32px;
    top: 65%;
    right: 18%;
    transform: rotate(15deg);
  }

  .paw-3 {
    width: 28px;
    bottom: 20%;
    left: 22%;
    transform: rotate(-10deg);
  }

  @media (max-width: 640px) {
    .title {
      font-size: 2.5rem;
    }

    .slogan {
      font-size: 1.05rem;
    }

    .subtitle {
      font-size: 1rem;
    }

    .app-icon {
      width: 100px;
      height: 100px;
    }

    .cta-group {
      flex-direction: column;
      width: 100%;
      max-width: 240px;
    }

    .btn {
      justify-content: center;
    }
  }
</style>
