---
interface Props {
  active?: "home" | "details";
}

const { active = "home" } = Astro.props;
---

<nav class="nav">
  <a href="/" class="nav-brand">
    <img src="/images/prowl-icon.png" alt="Prowl" class="nav-icon" />
    <span class="nav-name">Prowl</span>
  </a>
  <div class="nav-links">
    <a href="/" class:list={["nav-link", { active: active === "home" }]}>
      Home
    </a>
    <a
      href="/details"
      class:list={["nav-link", { active: active === "details" }]}
    >
      Details
    </a>
    <a
      href="https://github.com/onevcat/Prowl"
      class="nav-link nav-github"
      target="_blank"
      rel="noopener"
    >
      GitHub
      <svg class="nav-star-icon" viewBox="0 0 16 16" fill="currentColor" width="14" height="14" aria-label="Star on GitHub">
        <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z" />
      </svg>
    </a>
  </div>
</nav>

<script>
  const nav = document.querySelector(".nav")!;
  window.addEventListener("scroll", () => {
    nav.classList.toggle("scrolled", window.scrollY > 10);
  }, { passive: true });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    background: var(--bg-primary);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .nav::after {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-attachment: fixed;
    pointer-events: none;
  }

  .nav.scrolled {
    border-bottom-color: rgba(136, 153, 180, 0.08);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.15);
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .nav-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
  }

  .nav-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    font-family: var(--font-mono);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--text-primary);
    opacity: 1;
  }

  .nav-link.active {
    color: var(--accent);
  }

  .nav-github {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-star-icon {
    color: var(--text-muted);
    transition: color 0.2s, transform 0.2s;
  }

  .nav-github:hover .nav-star-icon {
    color: #f5a623;
    transform: scale(1.15);
  }
</style>
