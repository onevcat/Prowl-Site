---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout title="Prowl — Quiet paws. Sharp claws.">
  <Nav active="home" />

  <main class="hero">
    <div class="hero-layout">
      <!-- Left: text content -->
      <div class="hero-text">
        <h1 class="title">Prowl</h1>
        <p class="slogan">Quiet paws.<br />Sharp claws.</p>
        <p class="subtitle">
          A native macOS terminal environment, sharpened for coding agents.
        </p>

        <div class="cta-group">
          <a
            href="https://github.com/onevcat/Prowl/releases/latest/download/Prowl.dmg"
            class="btn btn-primary"
            target="_blank"
            rel="noopener"
          >
            <svg
              class="btn-icon"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12v1.5h10V12" />
            </svg>
            Download
          </a>
          <a href="/details" class="btn btn-secondary">
            Details
            <svg
              class="btn-icon"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M6 3l5 5-5 5" />
            </svg>
          </a>
        </div>
        <p class="brew-note">
          Or install through Homebrew:
          <br />
          <span class="brew-command" id="brew-command">brew install --cask onevcat/tap/prowl</span>
          <button
            type="button"
            class="brew-copy"
            id="brew-copy"
            aria-label="Copy Homebrew install command"
          >
            Copy
          </button>
        </p>

        <p class="fork-note">
          Free &amp; Open Source. A personal fork of <a
            href="https://supacode.sh/"
            target="_blank"
            rel="noopener">Supacode</a
          >, built for daily use.
        </p>
      </div>

      <!-- Right: interactive mini app wireframe + icon -->
      <div class="hero-visual">
        <div class="app-frame" id="app-frame">
          <!-- Title bar -->
          <div class="frame-titlebar">
            <div class="frame-dots">
              <span class="fdot fdot-r"></span>
              <span class="fdot fdot-y"></span>
              <span class="fdot fdot-g"></span>
            </div>
            <span class="frame-title">Prowl</span>
          </div>
          <div class="frame-content">
            <!-- Vertical tab sidebar -->
            <div class="frame-sidebar">
              <div class="sidebar-action view-toggles">
                <span class="view-link" id="canvas-toggle" title="Toggle Canvas view">Canvas</span>
                <span class="view-link" id="shelf-toggle" title="Toggle Shelf view">Shelf</span>
              </div>
              <div class="tab active" data-tab="prowl">
                <span class="tab-icon">&#9733;</span>
                <span class="tab-label">prowl</span>
                <span class="tab-badge running"></span>
              </div>
              <div class="tab" data-tab="kingfisher">
                <span class="tab-icon">&#9733;</span>
                <span class="tab-label">kingfisher</span>
                <span class="tab-badge running"></span>
              </div>
              <div class="tab" data-tab="meetcat">
                <span class="tab-icon">&#9733;</span>
                <span class="tab-label">MeetCat</span>
                <span class="tab-badge running"></span>
              </div>
              <div class="tab" data-tab="yitong">
                <span class="tab-icon">&#9733;</span>
                <span class="tab-label">YiTong</span>
                <span class="tab-badge idle"></span>
              </div>
            </div>
            <!-- Main area -->
            <div class="frame-main">
              <!-- Shelf view: [unselected spines] [selected spine] [book/terminal] [unselected spines] -->
              <div class="shelf-panel" id="shelf-panel">
                <div class="spine" data-book="prowl" id="shelf-spine-prowl">
                  <span class="spine-label">prowl</span>
                  <span class="spine-icons">
                    <i class="sicon" data-glyph="swift">▲</i>
                    <i class="sicon" data-glyph="claude">✦</i>
                  </span>
                </div>
                <div class="spine spine-selected" data-book="kingfisher" id="shelf-spine-kingfisher">
                  <span class="spine-label">kingfisher</span>
                  <span class="spine-icons">
                    <i class="sicon active" data-glyph="codex">❯</i>
                    <i class="sicon" data-glyph="git">◆</i>
                  </span>
                </div>
                <div class="shelf-book" id="shelf-book">
                  <div class="book-toolbar">
                    <span class="book-repo" id="shelf-book-repo">kingfisher</span>
                    <span class="book-branch">main</span>
                  </div>
                  <div class="book-terminal" id="shelf-book-term">
                    <div class="bl"><span class="bp">&#10095;</span> codex "Add retry to ImageDownloader"</div>
                    <div class="bl out">  &#8987; Reading ImageDownloader.swift</div>
                    <div class="bl out ok">  &#10003; Done. 3 files changed.</div>
                    <div class="bl"><span class="bp">&#10095;</span><span class="blink">&#9646;</span></div>
                  </div>
                </div>
                <div class="spine" data-book="yitong" id="shelf-spine-yitong">
                  <span class="spine-label">YiTong</span>
                  <span class="spine-icons">
                    <i class="sicon" data-glyph="vim">▦</i>
                  </span>
                </div>
                <div class="spine" data-book="meetcat" id="shelf-spine-meetcat">
                  <span class="spine-label">MeetCat</span>
                  <span class="spine-icons">
                    <i class="sicon" data-glyph="vitest">✓</i>
                    <i class="sicon" data-glyph="npm">▣</i>
                  </span>
                </div>
              </div>
              <!-- Canvas 2x2 grid view -->
              <div class="canvas-panel" id="canvas-panel">
                <div class="canvas-grid">
                  <div class="canvas-card" data-card="prowl">
                    <div class="card-title">prowl</div>
                    <div class="card-body">
                      <span class="card-line ok">&#10003; 23 tests passed</span>
                    </div>
                  </div>
                  <div class="canvas-card" data-card="kingfisher">
                    <div class="card-title">kingfisher</div>
                    <div class="card-body">
                      <span class="card-line">codex &#8230; 3 files</span>
                    </div>
                  </div>
                  <div class="canvas-card" data-card="meetcat">
                    <div class="card-title">MeetCat</div>
                    <div class="card-body">
                      <span class="card-line ok">&#10003; 10 tests passed</span>
                    </div>
                  </div>
                  <div class="canvas-card" data-card="yitong">
                    <div class="card-title">YiTong</div>
                    <div class="card-body">
                      <span class="card-line diff-r">- The next idea</span>
                      <span class="card-line diff-a">+ &#24322;&#21516;</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- prowl -->
              <div class="tab-panel active" data-panel="prowl">
                <div class="frame-toolbar">
                  <span class="toolbar-repo">prowl</span>
                  <div class="toolbar-actions">
                    <span class="action-btn" data-run="prowl-run">&#9654; Run</span>
                    <span class="action-btn" data-run="prowl-test">&#9881; Test</span>
                  </div>
                </div>
                <div class="frame-terminal" id="term-prowl">
                  <div class="tl"><span class="tp">&#10095;</span> swift test</div>
                  <div class="tl out">  Build complete! (1.2s)</div>
                  <div class="tl out ok">  Test Suite passed — 23 tests, 0 failures</div>
                  <div class="tl"><span class="tp">&#10095;</span><span class="blink">&#9646;</span></div>
                </div>
              </div>
              <!-- kingfisher -->
              <div class="tab-panel" data-panel="kingfisher">
                <div class="frame-toolbar">
                  <span class="toolbar-repo">kingfisher</span>
                  <div class="toolbar-actions">
                    <span class="action-btn" data-run="kf-build">&#9654; Build</span>
                    <span class="action-btn" data-run="kf-release">&#9881; Release</span>
                  </div>
                </div>
                <div class="frame-terminal" id="term-kingfisher">
                  <div class="tl agent"><span class="tp">&#10095;</span> codex "Add retry to ImageDownloader"</div>
                  <div class="tl out">  &#8987; Reading ImageDownloader.swift</div>
                  <div class="tl out">  &#8987; Applying changes to 2 files</div>
                  <div class="tl out ok">  &#10003; Done. 3 files changed.</div>
                  <div class="tl"><span class="tp">&#10095;</span><span class="blink">&#9646;</span></div>
                </div>
              </div>
              <!-- meetcat -->
              <div class="tab-panel" data-panel="meetcat">
                <div class="frame-toolbar">
                  <span class="toolbar-repo">MeetCat</span>
                  <div class="toolbar-actions">
                    <span class="action-btn" data-run="mc-app">&#9654; Open App</span>
                    <a class="action-btn action-link" href="https://meet.onev.cat" target="_blank" rel="noopener">&#9741; WebSite</a>
                  </div>
                </div>
                <div class="frame-terminal" id="term-meetcat">
                  <div class="tl"><span class="tp">&#10095;</span> npx vitest run</div>
                  <div class="tl out">  &#10003; src/utils.test.ts (6 tests) 12ms</div>
                  <div class="tl out">  &#10003; src/hooks.test.ts (4 tests) 8ms</div>
                  <div class="tl out ok">  Tests  10 passed</div>
                  <div class="tl"><span class="tp">&#10095;</span><span class="blink">&#9646;</span></div>
                </div>
              </div>
              <!-- yitong -->
              <div class="tab-panel" data-panel="yitong">
                <div class="frame-toolbar">
                  <span class="toolbar-repo">YiTong</span>
                  <div class="toolbar-actions">
                    <span class="action-btn" data-run="yt-build">&#9654; Build</span>
                    <span class="action-btn" data-run="yt-diff">&#8800; Diff</span>
                  </div>
                </div>
                <div class="frame-terminal frame-diff" id="term-yitong">
                  <div class="tl diff-remove">- The next idea</div>
                  <div class="tl diff-add">+ YiTong</div>
                  <div class="tl diff-add">+ &#24322;&#21516;</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating icon -->
        <div class="icon-float">
          <img
            src="/images/prowl-icon.png"
            alt="Prowl App Icon"
            class="app-icon"
          />
        </div>

      </div>

      <!-- Paw prints between title and terminal -->
      <div class="paw-bridge">
        <svg
          class="paw p1"
          data-paw
          viewBox="0 0 20 20"
          fill="currentColor"
          role="button"
          tabindex="0"
          aria-label="Toggle bright paw"
        >
          <ellipse cx="6.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="13.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="3.2" cy="8.8" rx="1.7" ry="2.1" />
          <ellipse cx="16.8" cy="8.8" rx="1.7" ry="2.1" />
          <path d="M10 18.5c-3.2 0-5.8-2.2-5.8-4.5 0-2 1.6-3.5 3.2-3.5.9 0 1.4.6 2.6.6s1.7-.6 2.6-.6c1.6 0 3.2 1.5 3.2 3.5 0 2.3-2.6 4.5-5.8 4.5z" />
        </svg>
        <svg
          class="paw p2"
          data-paw
          viewBox="0 0 20 20"
          fill="currentColor"
          role="button"
          tabindex="0"
          aria-label="Toggle bright paw"
        >
          <ellipse cx="6.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="13.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="3.2" cy="8.8" rx="1.7" ry="2.1" />
          <ellipse cx="16.8" cy="8.8" rx="1.7" ry="2.1" />
          <path d="M10 18.5c-3.2 0-5.8-2.2-5.8-4.5 0-2 1.6-3.5 3.2-3.5.9 0 1.4.6 2.6.6s1.7-.6 2.6-.6c1.6 0 3.2 1.5 3.2 3.5 0 2.3-2.6 4.5-5.8 4.5z" />
        </svg>
        <svg
          class="paw p3"
          data-paw
          viewBox="0 0 20 20"
          fill="currentColor"
          role="button"
          tabindex="0"
          aria-label="Toggle bright paw"
        >
          <ellipse cx="6.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="13.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="3.2" cy="8.8" rx="1.7" ry="2.1" />
          <ellipse cx="16.8" cy="8.8" rx="1.7" ry="2.1" />
          <path d="M10 18.5c-3.2 0-5.8-2.2-5.8-4.5 0-2 1.6-3.5 3.2-3.5.9 0 1.4.6 2.6.6s1.7-.6 2.6-.6c1.6 0 3.2 1.5 3.2 3.5 0 2.3-2.6 4.5-5.8 4.5z" />
        </svg>
      </div>
    </div>

    <footer class="footer">
      <p>
        Built by <a
          href="https://github.com/onevcat"
          target="_blank"
          rel="noopener">@onevcat</a
        > with <span class="heart">&hearts;</span>
      </p>
    </footer>

  </main>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLElement>(".tab[data-tab]");
  const panels = document.querySelectorAll<HTMLElement>(".tab-panel[data-panel]");
  const canvasPanel = document.getElementById("canvas-panel")!;
  const canvasToggle = document.getElementById("canvas-toggle")!;
  const shelfPanel = document.getElementById("shelf-panel")!;
  const shelfToggle = document.getElementById("shelf-toggle")!;
  const shelfBook = document.getElementById("shelf-book")!;
  const shelfBookRepo = document.getElementById("shelf-book-repo")!;
  const shelfBookTerm = document.getElementById("shelf-book-term")!;
  const tabNames = ["prowl", "kingfisher", "meetcat", "yitong"];
  // Rotation: canvas → shelf → prowl → kingfisher → meetcat → yitong → canvas ...
  const sequence = ["canvas", "shelf", ...tabNames];
  let seqIndex = sequence.indexOf("prowl");
  let timer: ReturnType<typeof setInterval>;
  const INTERVAL = 5000;

  type BookContent = { repo: string; lines: string };
  const shelfBooks: Record<string, BookContent> = {
    prowl: {
      repo: "prowl",
      lines:
        '<div class="bl"><span class="bp">&#10095;</span> swift test</div>' +
        '<div class="bl out">  Build complete! (1.2s)</div>' +
        '<div class="bl out ok">  Test Suite passed — 23 tests</div>' +
        '<div class="bl"><span class="bp">&#10095;</span><span class="blink">&#9646;</span></div>',
    },
    kingfisher: {
      repo: "kingfisher",
      lines:
        '<div class="bl"><span class="bp">&#10095;</span> codex "Add retry to ImageDownloader"</div>' +
        '<div class="bl out">  &#8987; Reading ImageDownloader.swift</div>' +
        '<div class="bl out ok">  &#10003; Done. 3 files changed.</div>' +
        '<div class="bl"><span class="bp">&#10095;</span><span class="blink">&#9646;</span></div>',
    },
    meetcat: {
      repo: "MeetCat",
      lines:
        '<div class="bl"><span class="bp">&#10095;</span> npx vitest run</div>' +
        '<div class="bl out">  &#10003; src/utils.test.ts (6) 12ms</div>' +
        '<div class="bl out ok">  Tests  10 passed</div>' +
        '<div class="bl"><span class="bp">&#10095;</span><span class="blink">&#9646;</span></div>',
    },
    yitong: {
      repo: "YiTong",
      lines:
        '<div class="bl"><span class="bp">&#10095;</span> vim README.md</div>' +
        '<div class="bl out">  -- INSERT --</div>' +
        '<div class="bl out">  saved · 1 file</div>' +
        '<div class="bl"><span class="bp">&#10095;</span><span class="blink">&#9646;</span></div>',
    },
  };

  function clearViewToggles() {
    canvasToggle.classList.remove("active");
    shelfToggle.classList.remove("active");
    canvasPanel.classList.remove("active");
    shelfPanel.classList.remove("active");
  }

  function showTab(name: string) {
    clearViewToggles();
    tabs.forEach((t) => t.classList.toggle("active", t.dataset.tab === name));
    panels.forEach((p) => p.classList.toggle("active", p.dataset.panel === name));
  }

  function showCanvas() {
    panels.forEach((p) => p.classList.remove("active"));
    tabs.forEach((t) => t.classList.remove("active"));
    clearViewToggles();
    canvasPanel.classList.add("active");
    canvasToggle.classList.add("active");
  }

  // Mutable book order; selected lives at shelfSelectedIdx. Books before it
  // sit on the left of the terminal, books after sit on the right. Clicking
  // a right-side book splices it into the selected slot and the previously
  // selected book is pushed to the head of the right side.
  const shelfBookOrder = ["prowl", "kingfisher", "yitong", "meetcat"];
  let shelfSelectedIdx = 1; // markup default: kingfisher is selected

  function shelfElementOf(book: string): HTMLElement | null {
    return document.getElementById("shelf-spine-" + book);
  }

  function shelfApplyOrder() {
    shelfBookOrder.forEach((book, idx) => {
      const el = shelfElementOf(book);
      if (!el) return;
      el.style.order = String(idx <= shelfSelectedIdx ? idx : idx + 1);
      el.classList.toggle("spine-selected", idx === shelfSelectedIdx);
    });
    shelfBook.style.order = String(shelfSelectedIdx + 1);
  }

  function openShelfBook(name: string) {
    const book = shelfBooks[name];
    if (!book) return;

    // Always update visual cues (terminal content + repo label)
    shelfBookRepo.textContent = book.repo;
    shelfBookTerm.innerHTML = book.lines;

    const idx = shelfBookOrder.indexOf(name);
    if (idx === -1 || idx === shelfSelectedIdx) return;

    // FIRST: snapshot every spine + the terminal book
    const allTargets: HTMLElement[] = shelfBookOrder
      .map(shelfElementOf)
      .filter((el): el is HTMLElement => el !== null);
    allTargets.push(shelfBook);
    const firstRects = new Map<HTMLElement, DOMRect>();
    allTargets.forEach((el) => firstRects.set(el, el.getBoundingClientRect()));

    // LAST: mutate state + reapply order
    if (idx < shelfSelectedIdx) {
      shelfSelectedIdx = idx;
    } else {
      const moved = shelfBookOrder.splice(idx, 1)[0];
      shelfBookOrder.splice(shelfSelectedIdx, 0, moved);
    }
    shelfApplyOrder();

    // INVERT: each target jumps back to its FIRST position with no transition
    allTargets.forEach((el) => {
      const dx = firstRects.get(el)!.left - el.getBoundingClientRect().left;
      if (Math.abs(dx) < 0.5) {
        el.style.transition = "";
        el.style.transform = "";
        return;
      }
      el.style.transition = "none";
      el.style.transform = `translateX(${dx}px)`;
    });

    // PLAY: commit the invert, then animate to identity in the next frame
    void shelfPanel.offsetWidth;
    requestAnimationFrame(() => {
      allTargets.forEach((el) => {
        el.style.transition = "transform 380ms cubic-bezier(0.4, 0, 0.2, 1)";
        el.style.transform = "";
      });
    });
  }

  // Initialise flex order to match the markup default
  shelfApplyOrder();

  function showShelf() {
    panels.forEach((p) => p.classList.remove("active"));
    tabs.forEach((t) => t.classList.remove("active"));
    clearViewToggles();
    shelfPanel.classList.add("active");
    shelfToggle.classList.add("active");
  }

  function showByIndex(i: number) {
    const name = sequence[i];
    if (name === "canvas") {
      showCanvas();
    } else if (name === "shelf") {
      showShelf();
    } else {
      showTab(name);
    }
  }

  function advance() {
    seqIndex = (seqIndex + 1) % sequence.length;
    showByIndex(seqIndex);
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(advance, INTERVAL);
  }

  function switchTo(name: string) {
    seqIndex = sequence.indexOf(name);
    showByIndex(seqIndex);
    resetTimer();
  }

  // Tab clicks
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => switchTo(tab.dataset.tab!));
  });

  // Canvas toggle
  canvasToggle.addEventListener("click", () => switchTo("canvas"));

  // Shelf toggle
  shelfToggle.addEventListener("click", () => switchTo("shelf"));

  // Canvas card clicks → switch to that tab
  document.querySelectorAll<HTMLElement>(".canvas-card[data-card]").forEach((card) => {
    card.addEventListener("click", () => switchTo(card.dataset.card!));
  });

  // Shelf spine clicks → open that book inside the shelf
  shelfPanel.querySelectorAll<HTMLElement>(".spine[data-book]").forEach((spine) => {
    spine.addEventListener("click", (event) => {
      event.stopPropagation();
      openShelfBook(spine.dataset.book!);
      // Stay in shelf view; reset rotation timer for breathing room
      switchTo("shelf");
    });
  });

  // Action button flash
  document.querySelectorAll<HTMLElement>(".action-btn[data-run]").forEach((btn) => {
    btn.addEventListener("click", () => {
      btn.classList.add("flash");
      setTimeout(() => btn.classList.remove("flash"), 400);
    });
  });

  const brewCopyButton = document.getElementById("brew-copy") as HTMLButtonElement | null;
  const brewCommand = document.getElementById("brew-command")?.textContent?.trim();
  brewCopyButton?.addEventListener("click", async () => {
    if (!brewCommand || !brewCopyButton) return;

    try {
      await navigator.clipboard.writeText(brewCommand);
      brewCopyButton.textContent = "Copied!";
      brewCopyButton.classList.add("copied");
      window.setTimeout(() => {
        brewCopyButton.textContent = "Copy";
        brewCopyButton.classList.remove("copied");
      }, 1200);
    } catch (_error) {
      brewCopyButton.textContent = "Copy failed";
      window.setTimeout(() => {
        brewCopyButton.textContent = "Copy";
      }, 1200);
    }
  });

  const pawPrints = document.querySelectorAll<HTMLElement>(".paw[data-paw]");
  pawPrints.forEach((paw) => {
    paw.setAttribute("aria-pressed", "false");
  });

  function togglePaw(paw: HTMLElement) {
    const isLit = paw.classList.toggle("lit");
    paw.setAttribute("aria-pressed", String(isLit));
  }

  document.addEventListener("click", (event) => {
    const x = event.clientX;
    const y = event.clientY;
    for (const paw of pawPrints) {
      const rect = paw.getBoundingClientRect();
      if (x >= rect.left && x <= rect.right && y >= rect.top && y <= rect.bottom) {
        togglePaw(paw);
        break;
      }
    }
  });

  pawPrints.forEach((paw) => {
    paw.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        togglePaw(paw);
      }
    });
  });

  // Start auto-rotation
  resetTimer();
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 70% 50%, rgba(90, 228, 192, 0.04) 0%, transparent 60%),
      var(--bg-primary);
  }

  /* Layout: left text, right visual */
  .hero-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 3rem;
    align-items: center;
    max-width: 1080px;
    width: 100%;
    padding: 6rem 3rem 3rem;
  }

  /* ---- Left: text ---- */
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .title {
    font-family: var(--font-mono);
    font-size: 4.5rem;
