---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout title="Prowl — Details">
  <Nav active="details" />

  <main class="details-page">

    <!-- ═══ Prologue ═══ -->
    <section class="act act-prologue" id="prologue">
      <div class="act-inner">
        <h1 class="prologue-title">
          Your terminal wasn't built for <span class="accent">agents</span>.
        </h1>
        <p class="prologue-sub">
          You're not just typing commands anymore — you're orchestrating AI agents
          across repos, branches, and ideas. Everything changed. Except your terminal.
        </p>
        <p class="prologue-sub prologue-sub-alt">
          Until now.
        </p>
        <div class="scroll-hint" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24">
            <path d="M12 5v14m0 0l-5-5m5 5l5-5" />
          </svg>
        </div>
      </div>
      <div class="prologue-hero-image">
        <img
          src="/images/promotion.webp"
          alt="Prowl app — vertical tabs, terminal, command palette, and split view"
          class="hero-screenshot"
        />
      </div>
    </section>

    <!-- ═══ Act 1 — Canvas ═══ -->
    <section class="act act-canvas" id="act-canvas">
      <div class="act-pin-wrap">
        <div class="act-layout">
          <div class="act-text">
            <span class="act-label">01</span>
            <h2 class="act-title">Canvas</h2>
            <p class="act-scene">
              Three agents running. One just finished.
              <br />Where?
            </p>
            <p class="act-resolve">
              Canvas gives you the bird's-eye view — every card is a
              real, live terminal you can read and interact with.
            </p>
            <ul class="act-details">
              <li>Each card is a live terminal — not a thumbnail, not a preview</li>
              <li>Finished tasks light up instantly so you never miss a completion</li>
              <li>Broadcast one message to multiple agents at once</li>
            </ul>
          </div>
          <div class="act-visual">
            <div class="canvas-demo" id="canvas-demo">
              <div class="canvas-card c-card" id="cc-1">
                <div class="cc-title" id="cc-1-title">prowl <span class="cc-badge running" id="cc-1-badge"></span></div>
                <div class="cc-body">
                  <span class="cc-line ok">&#10003; 23 tests passed</span>
                </div>
                <div class="canvas-done-pulse" id="canvas-done-pulse"></div>
              </div>
              <div class="canvas-card c-card" id="cc-2">
                <div class="cc-title">kingfisher <span class="cc-badge running"></span></div>
                <div class="cc-body">
                  <span class="cc-line">codex &#8230; 3 files</span>
                </div>
              </div>
              <div class="canvas-card c-card" id="cc-3">
                <div class="cc-title">MeetCat <span class="cc-badge running"></span></div>
                <div class="cc-body">
                  <span class="cc-line">vitest run &#8230;</span>
                </div>
              </div>
              <div class="canvas-card c-card" id="cc-4">
                <div class="cc-title">YiTong <span class="cc-badge idle"></span></div>
                <div class="cc-body">
                  <span class="cc-line muted">idle</span>
                </div>
              </div>
              <!-- Broadcast bar -->
              <div class="canvas-broadcast" id="canvas-broadcast">
                <span class="broadcast-icon">&#9654;</span>
                <span class="broadcast-text">Send to all: <span class="accent">npm run lint</span></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Act 2 — Shelf ═══ -->
    <section class="act act-shelf" id="act-shelf">
      <div class="act-pin-wrap">
        <div class="act-layout act-layout-reverse">
          <div class="act-text">
            <span class="act-label">02</span>
            <h2 class="act-title">Shelf</h2>
            <p class="act-scene">
              Five repos open. Each one a different agent, a different command.
              <br />You need the next one — without losing this one.
            </p>
            <p class="act-resolve">
              Shelf gives every worktree its own spine. One book open, the rest
              standing by — click a spine, the shelf flows aside, your
              terminal opens like a book.
            </p>
            <ul class="act-details">
              <li>Spine icons follow the running command — codex, vitest, swift, git… one glance tells you what's alive</li>
              <li><kbd>&#8984;&#8963;&larr;/&rarr;</kbd> cycles books · <kbd>&#8984;&#8963;&uarr;/&darr;</kbd> cycles tabs</li>
              <li>Canvas zooms out to orchestrate. Shelf zooms in to focus — and switches without breaking it.</li>
            </ul>
          </div>
          <div class="act-visual">
            <div class="shelf-demo" id="shelf-demo">
              <div class="shelf-titlebar">
                <span class="shelf-dot r"></span>
                <span class="shelf-dot y"></span>
                <span class="shelf-dot g"></span>
                <span class="shelf-title" id="shelf-title">Prowl</span>
              </div>
              <div class="shelf-body" id="dshelf-body">
                <div class="dspine" data-book="ai-ship" id="dspine-ai-ship">
                  <span class="dspine-label">ai-ship</span>
                  <div class="dspine-icons">
                    <span class="dsicon">▦</span>
                    <span class="dsicon">◆</span>
                  </div>
                </div>
                <div class="dspine" data-book="kingfisher" id="dspine-kingfisher">
                  <span class="dspine-label">kingfisher</span>
                  <div class="dspine-icons">
                    <span class="dsicon" id="dspine-kf-i1">◆</span>
                    <span class="dsicon" id="dspine-kf-i2">❯</span>
                    <span class="dsicon" id="dspine-kf-i3">✓</span>
                  </div>
                </div>
                <div class="dspine dspine-selected" data-book="prowl" id="dspine-prowl">
                  <span class="dspine-label">prowl</span>
                  <div class="dspine-icons">
                    <span class="dsicon active">▲</span>
                    <span class="dsicon">✦</span>
                    <span class="dsicon">◆</span>
                  </div>
                </div>
                <div class="dshelf-book" id="dshelf-book">
                  <div class="dbook-toolbar">
                    <span class="dbook-repo" id="dbook-repo">prowl</span>
                    <span class="dbook-branch" id="dbook-branch">main</span>
                    <span class="dbook-controls">
                      <span class="dbook-ctrl">+</span>
                      <span class="dbook-ctrl">⊟</span>
                    </span>
                  </div>
                  <div class="dbook-terminal" id="dbook-terminal">
                    <div class="dbl"><span class="dbp">&#10095;</span> swift test</div>
                    <div class="dbl out">  Build complete! (1.2s)</div>
                    <div class="dbl out ok">  Test Suite passed — 23 tests, 0 failures</div>
                    <div class="dbl"><span class="dbp">&#10095;</span><span class="dblink">&#9646;</span></div>
                  </div>
                </div>
                <div class="dspine" data-book="yitong" id="dspine-yitong">
                  <span class="dspine-label">YiTong</span>
                  <div class="dspine-icons">
                    <span class="dsicon">▦</span>
                  </div>
                </div>
                <div class="dspine" data-book="meetcat" id="dspine-meetcat">
                  <span class="dspine-label">MeetCat</span>
                  <div class="dspine-icons">
                    <span class="dsicon">▣</span>
                    <span class="dsicon">✓</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Act 3 — CLI ═══ -->
    <section class="act act-cli" id="act-cli">
      <div class="act-pin-wrap">
        <div class="act-layout act-layout-reverse">
          <div class="act-text">
            <span class="act-label">03</span>
            <h2 class="act-title">CLI</h2>
            <p class="act-scene">
              Your agent needs to run a test, read the result,
              and decide what to do next.
              <br />In most terminals, it's flying blind.
            </p>
            <p class="act-resolve">
              Prowl exposes a full CLI that both you and your agents
              can use to control the terminal programmatically — send
              commands, capture output, orchestrate multiple panes.
            </p>
            <ul class="act-details">
              <li><kbd>prowl list</kbd> — discover all panes &amp; their status</li>
              <li><kbd>prowl send --capture</kbd> — execute &amp; capture output in one shot</li>
              <li><kbd>prowl read</kbd> — read screen content on demand</li>
              <li><kbd>prowl key</kbd> — send keystrokes programmatically</li>
              <li>Multi-agent orchestration, CI scripting, automated workflows — the only limit is your imagination</li>
            </ul>
          </div>
          <div class="act-visual">
            <div class="cli-demo" id="cli-demo">
              <div class="cli-titlebar">
                <span class="cli-dot r"></span>
                <span class="cli-dot y"></span>
                <span class="cli-dot g"></span>
                <span class="cli-title">Terminal</span>
              </div>
              <div class="cli-body">
                <div class="cli-line" id="cli-l1"><span class="cli-prompt">$</span> prowl list --json</div>
                <div class="cli-line cli-out" id="cli-l2">&#9656; prowl &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;(3 tabs) <span class="ok">&#9679; running</span></div>
                <div class="cli-line cli-out" id="cli-l3">&#9656; kingfisher &nbsp;(1 tab) &nbsp;<span class="muted">&#9675; idle</span></div>
                <div class="cli-line cli-blank" id="cli-l4">&nbsp;</div>
                <div class="cli-line" id="cli-l5"><span class="cli-prompt">$</span> prowl send "npm test" --capture</div>
                <div class="cli-line cli-out" id="cli-l6"><span class="muted">&#9203; waiting for shell&#8230;</span></div>
                <div class="cli-line cli-out" id="cli-l7"><span class="ok">&#10003; exit 0</span> <span class="muted">(3.2s)</span></div>
                <div class="cli-line cli-blank" id="cli-l8">&nbsp;</div>
                <div class="cli-line cli-out cli-captured" id="cli-l9">captured output:</div>
                <div class="cli-line cli-out cli-captured" id="cli-l10">&nbsp;&nbsp;Tests &nbsp;12 passed</div>
                <div class="cli-line cli-out cli-captured" id="cli-l11">&nbsp;&nbsp;Time &nbsp;&nbsp;3.18s</div>
                <div class="cli-line" id="cli-l12"><span class="cli-prompt">$</span> <span class="cli-cursor">&#9646;</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Act 4 — Custom Actions ═══ -->
    <section class="act act-actions" id="act-actions">
      <div class="act-pin-wrap">
        <div class="act-layout">
          <div class="act-text">
            <span class="act-label">04</span>
            <h2 class="act-title">Custom Actions</h2>
            <p class="act-scene">
              Build, test, deploy — the same commands, typed out the same way,
              in every repo, every single day. Stop repeating yourself.
            </p>
            <p class="act-resolve">
              Pin any workflow to a button. Trigger it with a keystroke.
              Pair it with <kbd>claude&nbsp;-p</kbd> or <kbd>codex&nbsp;exec</kbd>
              to turn your terminal into a daily AI-powered assistant.
            </p>
            <ul class="act-details">
              <li>Unlimited action buttons per repo — add as many as you need</li>
              <li>Shell script or direct terminal input, each with its own shortcut</li>
              <li>One keystroke to kick off builds, tests, agents, or deploy pipelines</li>
            </ul>
          </div>
          <div class="act-visual">
            <div class="actions-demo" id="actions-demo">
              <div class="actions-titlebar">
                <span class="actions-repo">prowl</span>
                <div class="actions-buttons">
                  <div class="action-pill" id="pill-build">
                    <span class="pill-icon">&#9654;</span> Build
                    <kbd class="pill-kbd">&#8984;B</kbd>
                  </div>
                  <div class="action-pill" id="pill-test">
                    <span class="pill-icon">&#9881;</span> Test
                    <kbd class="pill-kbd">&#8984;T</kbd>
                  </div>
                  <div class="action-pill" id="pill-deploy">
                    <span class="pill-icon">&#9650;</span> Deploy
                    <kbd class="pill-kbd">&#8984;D</kbd>
                  </div>
                </div>
              </div>
              <div class="actions-terminal" id="actions-terminal">
                <div class="actions-line" id="al-1"><span class="cli-prompt">&#10095;</span> swift build</div>
                <div class="actions-line actions-out" id="al-2">&nbsp;&nbsp;Compiling Prowl (42 sources)&#8230;</div>
                <div class="actions-line actions-out ok" id="al-3">&nbsp;&nbsp;Build complete! (4.8s)</div>
                <div class="actions-line" id="al-4"><span class="cli-prompt">&#10095;</span> <span class="cli-cursor">&#9646;</span></div>
              </div>
              <!-- Keystroke overlay -->
              <div class="keystroke-overlay" id="keystroke-overlay">
                <kbd class="keystroke-big">&#8984; B</kbd>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Interlude — Quick Features ═══ -->
    <section class="act act-interlude" id="act-interlude">
      <div class="interlude-inner">
        <p class="interlude-lead">And everything you'd expect from a modern terminal — done right.</p>
        <div class="interlude-grid">
          <div class="interlude-card" id="ic-native">
            <div class="ic-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32">
                <rect x="2" y="3" width="20" height="14" rx="2" />
                <path d="M8 21h8M12 17v4" />
              </svg>
            </div>
            <h3 class="ic-title">Full Native</h3>
            <p class="ic-desc">
              Powered by libghostty. No Electron, no web views —
              just raw native speed. No surprising edge cases,
              no rendering glitches. CJK-friendly out of the box.
            </p>
          </div>
          <div class="interlude-card" id="ic-tabs">
            <div class="ic-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32">
                <rect x="3" y="3" width="4" height="18" rx="1" />
                <path d="M10 6h8M10 10h6M10 14h8M10 18h4" />
              </svg>
            </div>
            <h3 class="ic-title">Vertical Tabs</h3>
            <p class="ic-desc">
              Repos, branches, and worktrees — organized in a sidebar.
              Switch context without losing your place.
            </p>
          </div>
          <div class="interlude-card" id="ic-reminder">
            <div class="ic-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32">
                <path d="M18 8A6 6 0 1 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" />
              </svg>
            </div>
            <h3 class="ic-title">Agent Reminder</h3>
            <p class="ic-desc">
              Get notified the moment an agent finishes — never miss
              a completion buried in background tabs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Finale — CTA ═══ -->
    <section class="act act-finale" id="act-finale">
      <div class="finale-inner">
        <p class="finale-title">Start prowling.</p>
        <p class="oss-note">Free &amp; Open Source</p>
        <div class="finale-cta">
          <a
            href="https://github.com/onevcat/Prowl/releases/latest/download/Prowl.dmg"
            class="btn btn-primary"
            target="_blank"
            rel="noopener"
          >
            Download Prowl
          </a>
          <a
            href="https://github.com/onevcat/Prowl"
            class="btn btn-secondary"
            target="_blank"
            rel="noopener"
          >
            View on GitHub
          </a>
        </div>
        <p class="brew-note">
          Or install via Homebrew:
          <br />
          <span class="brew-command" id="brew-command">brew install --cask onevcat/tap/prowl</span>
          <button type="button" class="brew-copy" id="brew-copy" aria-label="Copy Homebrew command">Copy</button>
        </p>
        <p class="fork-note">
          A personal fork of <a href="https://supacode.sh/" target="_blank" rel="noopener">Supacode</a>, built for daily use.
        </p>
      </div>
      <footer class="footer">
        <p>
          Built by <a href="https://github.com/onevcat" target="_blank" rel="noopener">@onevcat</a>
          with <span class="heart">&hearts;</span>
        </p>
      </footer>
    </section>

  </main>
</Layout>

<!-- GSAP + ScrollTrigger -->
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/gsap.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/ScrollTrigger.min.js"></script>

<script is:inline>
  gsap.registerPlugin(ScrollTrigger);

  /* ── Helpers ── */
  const mm = gsap.matchMedia();
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ── Prologue: fade out on scroll ── */
  if (!prefersReduced) {
    gsap.to("#prologue .act-inner", {
      opacity: 0,
      y: -60,
      ease: "none",
      scrollTrigger: {
        trigger: "#prologue",
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
    });
  }

  /* ── Prologue hero image: scale up gently ── */
  if (!prefersReduced) {
    gsap.from(".prologue-hero-image", {
      opacity: 0, y: 40, scale: 0.96,
      duration: 1, ease: "power2.out",
      scrollTrigger: {
        trigger: ".prologue-hero-image",
        start: "top 90%",
        toggleActions: "play none none none",
      },
    });
  }

  /* ── Act 1: Canvas ── */
  if (!prefersReduced) {
    const canvasTl = gsap.timeline({
      scrollTrigger: {
        trigger: "#act-canvas",
        pin: "#act-canvas .act-pin-wrap",
        start: "top top",
        end: "+=200%",
        scrub: 0.6,
      },
    });

    // Phase 1: cards start offset and scattered, animate to grid
    gsap.set("#cc-1", { x: -40, y: 30, rotation: -8, opacity: 0 });
    gsap.set("#cc-2", { x: 60, y: -20, rotation: 6, opacity: 0 });
    gsap.set("#cc-3", { x: -30, y: -40, rotation: 4, opacity: 0 });
    gsap.set("#cc-4", { x: 50, y: 50, rotation: -5, opacity: 0 });
    gsap.set("#canvas-broadcast", { opacity: 0, y: 20 });
    gsap.set("#canvas-done-pulse", { opacity: 0, scale: 0.8 });

    canvasTl
      .to(["#cc-1", "#cc-2", "#cc-3", "#cc-4"], {
        x: 0, y: 0, rotation: 0, opacity: 1,
        duration: 0.4, stagger: 0.05, ease: "power2.out",
      })
      // Phase 2: done pulse on card 1 + title turns golden
      .to("#cc-1-title", {
        background: "rgba(245, 166, 35, 0.15)",
        borderBottomColor: "rgba(245, 166, 35, 0.2)",
        duration: 0.2,
      }, "+=0.1")
      .to("#cc-1-badge", {
        background: "#f5a623",
        boxShadow: "0 0 6px rgba(245, 166, 35, 0.5)",
        duration: 0.2,
      }, "<")
      .to("#canvas-done-pulse", {
        opacity: 1, scale: 1, duration: 0.2,
      }, "<")
      // Phase 3: broadcast bar
      .to("#canvas-broadcast", {
        opacity: 1, y: 0, duration: 0.2,
      }, "+=0.1");

    // Text fade in
    gsap.from("#act-canvas .act-text", {
      opacity: 0, x: -40,
      scrollTrigger: {
        trigger: "#act-canvas",
        start: "top 80%",
        end: "top 30%",
        scrub: true,
      },
    });
  }

  /* ── Act 2: Shelf ──
     Spine flow stays inside its stack; "open" = innermost spine of a stack,
     visually merged with the terminal area. Terminal content + tint follows
     the open book; tab icons on the open spine cycle to suggest live commands.
  */
  if (!prefersReduced) {
    const shelfDemo = document.getElementById("shelf-demo");
    const dbookRepo = document.getElementById("dbook-repo");
    const dbookBranch = document.getElementById("dbook-branch");
    const dbookTerm = document.getElementById("dbook-terminal");
    const dshelfTitle = document.getElementById("shelf-title");

    const shelfScenes = {
      prowl: {
        open: "prowl",
        color: "rose",
        title: "Prowl",
        branch: "main",
        term:
          '<div class="dbl"><span class="dbp">&#10095;</span> swift test</div>' +
          '<div class="dbl out">  Build complete! (1.2s)</div>' +
          '<div class="dbl out ok">  Test Suite passed — 23 tests, 0 failures</div>' +
          '<div class="dbl"><span class="dbp">&#10095;</span><span class="dblink">&#9646;</span></div>',
      },
      kingfisher: {
        open: "kingfisher",
        color: "amber",
        title: "Kingfisher",
        branch: "main",
        term:
          '<div class="dbl"><span class="dbp">&#10095;</span> codex "Add retry to ImageDownloader"</div>' +
          '<div class="dbl out">  &#8987; Reading ImageDownloader.swift</div>' +
          '<div class="dbl out">  &#8987; Applying changes to 2 files</div>' +
          '<div class="dbl out ok">  &#10003; Done. 3 files changed.</div>' +
          '<div class="dbl"><span class="dbp">&#10095;</span><span class="dblink">&#9646;</span></div>',
      },
      "kingfisher-test": {
        open: "kingfisher",
        color: "amber",
        title: "Kingfisher",
        branch: "main",
        term:
          '<div class="dbl"><span class="dbp">&#10095;</span> swift test</div>' +
          '<div class="dbl out">  Test Suite started…</div>' +
          '<div class="dbl out ok">  &#10003; 142 passed (4.6s)</div>' +
          '<div class="dbl"><span class="dbp">&#10095;</span><span class="dblink">&#9646;</span></div>',
      },
      meetcat: {
        open: "meetcat",
        color: "teal",
        title: "MeetCat",
        branch: "feature/auth",
        term:
          '<div class="dbl"><span class="dbp">&#10095;</span> npx vitest run</div>' +
          '<div class="dbl out">  &#10003; src/utils.test.ts (6 tests) 12ms</div>' +
          '<div class="dbl out">  &#10003; src/hooks.test.ts (4 tests) 8ms</div>' +
          '<div class="dbl out ok">  Tests  10 passed</div>' +
          '<div class="dbl"><span class="dbp">&#10095;</span><span class="dblink">&#9646;</span></div>',
      },
    };

    /* Spines are arranged in a fixed order, like books on a shelf. The
       terminal slots in just to the right of the selected spine — selecting
       a different spine moves the terminal, never the spine order. */
    const dshelfBookOrder = ["ai-ship", "kingfisher", "prowl", "yitong", "meetcat"];
    let dshelfSelectedIdx = 2; // markup default: prowl is selected

    function dshelfElementOf(book) {
      return document.getElementById("dspine-" + book);
    }

    function dshelfApplyOrder() {
      const bookEl = document.getElementById("dshelf-book");
      dshelfBookOrder.forEach(function (book, idx) {
        const el = dshelfElementOf(book);
        if (!el) return;
        el.style.order = String(idx <= dshelfSelectedIdx ? idx : idx + 1);
        el.classList.toggle("dspine-selected", idx === dshelfSelectedIdx);
      });
      if (bookEl) bookEl.style.order = String(dshelfSelectedIdx + 1);
    }

    function dshelfSelect(book) {
      const idx = dshelfBookOrder.indexOf(book);
      if (idx === -1 || idx === dshelfSelectedIdx) return;

      // FIRST: snapshot every spine + the terminal book
      const allTargets = dshelfBookOrder.map(dshelfElementOf).filter(Boolean);
      const bookEl = document.getElementById("dshelf-book");
      if (bookEl) allTargets.push(bookEl);
      const firstRects = new Map();
      allTargets.forEach(function (el) { firstRects.set(el, el.getBoundingClientRect()); });

      // LAST: spine order is fixed; only the selected pointer moves, which
      // shifts the terminal's slot.
      dshelfSelectedIdx = idx;
      dshelfApplyOrder();

      // INVERT: each target jumps back to its FIRST position with no transition
      allTargets.forEach(function (el) {
        const first = firstRects.get(el);
        const dx = first.left - el.getBoundingClientRect().left;
        if (Math.abs(dx) < 0.5) {
          el.style.transition = "";
          el.style.transform = "";
          return;
        }
        el.style.transition = "none";
        el.style.transform = "translateX(" + dx + "px)";
      });

      // PLAY: commit the invert, then animate to identity in the next frame
      const body = document.getElementById("dshelf-body");
      if (body) void body.offsetWidth;
      requestAnimationFrame(function () {
        allTargets.forEach(function (el) {
          el.style.transition = "transform 380ms cubic-bezier(0.4, 0, 0.2, 1)";
          el.style.transform = "";
        });
      });
    }

    function applyShelfScene(key) {
      const scene = shelfScenes[key];
      if (!scene || !shelfDemo || !dbookRepo || !dbookBranch || !dbookTerm || !dshelfTitle) return;

      // Visual cues update immediately (no FLIP needed — they're tints/text)
      shelfDemo.dataset.color = scene.color;
      shelfDemo.dataset.open = scene.open;
      dbookRepo.textContent = scene.open === "meetcat" ? "MeetCat" : scene.open;
      dbookBranch.textContent = scene.branch;
      dbookTerm.innerHTML = scene.term;
      dshelfTitle.textContent = scene.title;

      // Spine selection — animates if scene.open differs from current selected
      dshelfSelect(scene.open);
    }

    // Sync the initial flex order to match the markup default
    dshelfApplyOrder();

    // Initialise to prowl scene
    applyShelfScene("prowl");

    const shelfTl = gsap.timeline({
      scrollTrigger: {
        trigger: "#act-shelf",
        pin: "#act-shelf .act-pin-wrap",
        start: "top top",
        end: "+=260%",
        scrub: 0.6,
      },
    });

    // Phase 1 (entry): spines + book fade in. We avoid x/y transforms here
    // because dshelfSelect() owns the transform property via FLIP — having
    // GSAP and FLIP both write to it would clobber.
    gsap.set(".dspine", { opacity: 0 });
    gsap.set("#dshelf-book", { opacity: 0 });

    shelfTl
      .to(".dspine", {
        opacity: 1, duration: 0.25, stagger: 0.04, ease: "power2.out",
      })
      .to("#dshelf-book", { opacity: 1, duration: 0.25 }, "<+0.1")
      // Phase 2: switch to kingfisher (left-stack flow).
      .add(() => applyShelfScene("kingfisher"), "+=0.25")
      // Phase 3: morph kingfisher's tab icon focus + change terminal to test run.
      .add(() => {
        const i1 = document.getElementById("dspine-kf-i1");
        const i2 = document.getElementById("dspine-kf-i2");
        const i3 = document.getElementById("dspine-kf-i3");
        i1?.classList.remove("active");
        i2?.classList.add("active");
        i3?.classList.remove("active");
      }, "+=0.3")
      .add(() => {
        applyShelfScene("kingfisher-test");
        const i1 = document.getElementById("dspine-kf-i1");
        const i2 = document.getElementById("dspine-kf-i2");
        const i3 = document.getElementById("dspine-kf-i3");
        i1?.classList.remove("active");
        i2?.classList.remove("active");
        i3?.classList.add("active");
      }, "+=0.3")
      // Phase 4: switch to meetcat (right-stack flow).
      .add(() => applyShelfScene("meetcat"), "+=0.3")
      // Tail dwell so the final scene reads.
      .to({}, { duration: 0.4 });

    gsap.from("#act-shelf .act-text", {
      opacity: 0, x: 40,
      scrollTrigger: {
        trigger: "#act-shelf",
        start: "top 80%",
        end: "top 30%",
        scrub: true,
      },
    });
  }

  /* ── Act 3: CLI ── */
  if (!prefersReduced) {
    const cliLines = Array.from({ length: 12 }, (_, i) => `#cli-l${i + 1}`);
    cliLines.forEach((sel) => gsap.set(sel, { opacity: 0, y: 8 }));

    const cliTl = gsap.timeline({
      scrollTrigger: {
        trigger: "#act-cli",
        pin: "#act-cli .act-pin-wrap",
        start: "top top",
        end: "+=250%",
        scrub: 0.6,
      },
    });

    // Reveal lines one by one
    cliLines.forEach((sel) => {
      cliTl.to(sel, { opacity: 1, y: 0, duration: 0.08 });
    });

    gsap.from("#act-cli .act-text", {
      opacity: 0, x: 40,
      scrollTrigger: {
        trigger: "#act-cli",
        start: "top 80%",
        end: "top 30%",
        scrub: true,
      },
    });
  }

  /* ── Act 4: Custom Actions ── */
  if (!prefersReduced) {
    gsap.set("#pill-build", { opacity: 0, y: 12 });
    gsap.set("#pill-test", { opacity: 0, y: 12 });
    gsap.set("#pill-deploy", { opacity: 0, y: 12 });
    gsap.set("#keystroke-overlay", { opacity: 0, scale: 1.3 });
    const actionLines = ["#al-1", "#al-2", "#al-3", "#al-4"];
    actionLines.forEach((sel) => gsap.set(sel, { opacity: 0, y: 8 }));

    const actionsTl = gsap.timeline({
      scrollTrigger: {
        trigger: "#act-actions",
        pin: "#act-actions .act-pin-wrap",
        start: "top top",
        end: "+=180%",
        scrub: 0.6,
      },
    });

    actionsTl
      // Phase 1: buttons appear
      .to("#pill-build", { opacity: 1, y: 0, duration: 0.1 })
      .to("#pill-test", { opacity: 1, y: 0, duration: 0.1 })
      .to("#pill-deploy", { opacity: 1, y: 0, duration: 0.1 })
      // Phase 2: keystroke flash
      .to("#keystroke-overlay", { opacity: 1, scale: 1, duration: 0.1 }, "+=0.05")
      .to("#keystroke-overlay", { opacity: 0, duration: 0.15 }, "+=0.1")
      .to("#pill-build", { background: "rgba(90,228,192,0.25)", duration: 0.1 }, "<")
      // Phase 3: terminal output
      .to("#al-1", { opacity: 1, y: 0, duration: 0.08 })
      .to("#al-2", { opacity: 1, y: 0, duration: 0.08 })
      .to("#al-3", { opacity: 1, y: 0, duration: 0.08 })
      .to("#al-4", { opacity: 1, y: 0, duration: 0.08 });

    gsap.from("#act-actions .act-text", {
      opacity: 0, x: -40,
      scrollTrigger: {
        trigger: "#act-actions",
        start: "top 80%",
        end: "top 30%",
        scrub: true,
      },
    });
  }

  /* ── Interlude: stagger fade-in ── */
  if (!prefersReduced) {
    gsap.from(".interlude-card", {
      opacity: 0, y: 40,
      stagger: 0.15,
      scrollTrigger: {
        trigger: "#act-interlude",
        start: "top 75%",
        end: "top 35%",
        scrub: true,
      },
    });
  }

  /* ── Brew copy ── */
  (function () {
    var btn = document.getElementById("brew-copy");
    var cmd = document.getElementById("brew-command");
    if (!btn || !cmd) return;
    btn.addEventListener("click", function () {
      navigator.clipboard.writeText(cmd.textContent.trim()).then(function () {
        btn.textContent = "Copied!";
        btn.classList.add("copied");
        setTimeout(function () {
          btn.textContent = "Copy";
          btn.classList.remove("copied");
        }, 1200);
      });
    });
  })();
</script>

