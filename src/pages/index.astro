---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
---

<Layout title="Prowl — Quiet paws. Sharp claws.">
  <Nav active="home" />

  <main class="hero">
    <div class="hero-layout">
      <!-- Left: text content -->
      <div class="hero-text">
        <h1 class="title">Prowl</h1>
        <p class="slogan">Quiet paws.<br />Sharp claws.</p>
        <p class="subtitle">
          A native macOS terminal environment, sharpened for coding agents.
        </p>

        <div class="cta-group">
          <a
            href="https://github.com/onevcat/Prowl/releases/latest/download/Prowl.dmg"
            class="btn btn-primary"
            target="_blank"
            rel="noopener"
          >
            <svg
              class="btn-icon"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12v1.5h10V12" />
            </svg>
            Download
          </a>
          <a href="/details" class="btn btn-secondary">
            Details
            <svg
              class="btn-icon"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M6 3l5 5-5 5" />
            </svg>
          </a>
        </div>
        <p class="brew-note">
          Or install through Homebrew:
          <br />
          <span class="brew-command" id="brew-command">brew install --cask onevcat/tap/prowl</span>
          <button
            type="button"
            class="brew-copy"
            id="brew-copy"
            aria-label="Copy Homebrew install command"
          >
            Copy
          </button>
        </p>

        <p class="fork-note">
          Free &amp; Open Source. A personal fork of <a
            href="https://supacode.sh/"
            target="_blank"
            rel="noopener">Supacode</a
          >, built for daily use.
        </p>
      </div>

      <!-- Right: interactive mini app wireframe + icon -->
      <div class="hero-visual">
        <div class="app-frame" id="app-frame">
          <!-- Title bar -->
          <div class="frame-titlebar">
            <div class="frame-dots">
              <span class="fdot fdot-r"></span>
              <span class="fdot fdot-y"></span>
              <span class="fdot fdot-g"></span>
            </div>
            <span class="frame-title">Prowl</span>
          </div>
          <div class="frame-content">
            <!-- Vertical tab sidebar -->
            <div class="frame-sidebar">
              <div class="sidebar-action canvas-link" id="canvas-toggle" title="Toggle Canvas view">Canvas</div>
              <div class="tab active" data-tab="prowl">
                <span class="tab-icon">&#9733;</span>
                <span class="tab-label">prowl</span>
                <span class="tab-badge running"></span>
              </div>
              <div class="tab" data-tab="kingfisher">
                <span class="tab-icon">&#9733;</span>
                <span class="tab-label">kingfisher</span>
                <span class="tab-badge running"></span>
              </div>
              <div class="tab" data-tab="meetcat">
                <span class="tab-icon">&#9733;</span>
                <span class="tab-label">MeetCat</span>
                <span class="tab-badge running"></span>
              </div>
              <div class="tab" data-tab="yitong">
                <span class="tab-icon">&#9733;</span>
                <span class="tab-label">YiTong</span>
                <span class="tab-badge idle"></span>
              </div>
            </div>
            <!-- Main area -->
            <div class="frame-main">
              <!-- Canvas 2x2 grid view -->
              <div class="canvas-panel" id="canvas-panel">
                <div class="canvas-grid">
                  <div class="canvas-card" data-card="prowl">
                    <div class="card-title">prowl</div>
                    <div class="card-body">
                      <span class="card-line ok">&#10003; 23 tests passed</span>
                    </div>
                  </div>
                  <div class="canvas-card" data-card="kingfisher">
                    <div class="card-title">kingfisher</div>
                    <div class="card-body">
                      <span class="card-line">codex &#8230; 3 files</span>
                    </div>
                  </div>
                  <div class="canvas-card" data-card="meetcat">
                    <div class="card-title">MeetCat</div>
                    <div class="card-body">
                      <span class="card-line ok">&#10003; 10 tests passed</span>
                    </div>
                  </div>
                  <div class="canvas-card" data-card="yitong">
                    <div class="card-title">YiTong</div>
                    <div class="card-body">
                      <span class="card-line diff-r">- The next idea</span>
                      <span class="card-line diff-a">+ &#24322;&#21516;</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- prowl -->
              <div class="tab-panel active" data-panel="prowl">
                <div class="frame-toolbar">
                  <span class="toolbar-repo">prowl</span>
                  <div class="toolbar-actions">
                    <span class="action-btn" data-run="prowl-run">&#9654; Run</span>
                    <span class="action-btn" data-run="prowl-test">&#9881; Test</span>
                  </div>
                </div>
                <div class="frame-terminal" id="term-prowl">
                  <div class="tl"><span class="tp">&#10095;</span> swift test</div>
                  <div class="tl out">  Build complete! (1.2s)</div>
                  <div class="tl out ok">  Test Suite passed — 23 tests, 0 failures</div>
                  <div class="tl"><span class="tp">&#10095;</span><span class="blink">&#9646;</span></div>
                </div>
              </div>
              <!-- kingfisher -->
              <div class="tab-panel" data-panel="kingfisher">
                <div class="frame-toolbar">
                  <span class="toolbar-repo">kingfisher</span>
                  <div class="toolbar-actions">
                    <span class="action-btn" data-run="kf-build">&#9654; Build</span>
                    <span class="action-btn" data-run="kf-release">&#9881; Release</span>
                  </div>
                </div>
                <div class="frame-terminal" id="term-kingfisher">
                  <div class="tl agent"><span class="tp">&#10095;</span> codex "Add retry to ImageDownloader"</div>
                  <div class="tl out">  &#8987; Reading ImageDownloader.swift</div>
                  <div class="tl out">  &#8987; Applying changes to 2 files</div>
                  <div class="tl out ok">  &#10003; Done. 3 files changed.</div>
                  <div class="tl"><span class="tp">&#10095;</span><span class="blink">&#9646;</span></div>
                </div>
              </div>
              <!-- meetcat -->
              <div class="tab-panel" data-panel="meetcat">
                <div class="frame-toolbar">
                  <span class="toolbar-repo">MeetCat</span>
                  <div class="toolbar-actions">
                    <span class="action-btn" data-run="mc-app">&#9654; Open App</span>
                    <a class="action-btn action-link" href="https://meet.onev.cat" target="_blank" rel="noopener">&#9741; WebSite</a>
                  </div>
                </div>
                <div class="frame-terminal" id="term-meetcat">
                  <div class="tl"><span class="tp">&#10095;</span> npx vitest run</div>
                  <div class="tl out">  &#10003; src/utils.test.ts (6 tests) 12ms</div>
                  <div class="tl out">  &#10003; src/hooks.test.ts (4 tests) 8ms</div>
                  <div class="tl out ok">  Tests  10 passed</div>
                  <div class="tl"><span class="tp">&#10095;</span><span class="blink">&#9646;</span></div>
                </div>
              </div>
              <!-- yitong -->
              <div class="tab-panel" data-panel="yitong">
                <div class="frame-toolbar">
                  <span class="toolbar-repo">YiTong</span>
                  <div class="toolbar-actions">
                    <span class="action-btn" data-run="yt-build">&#9654; Build</span>
                    <span class="action-btn" data-run="yt-diff">&#8800; Diff</span>
                  </div>
                </div>
                <div class="frame-terminal frame-diff" id="term-yitong">
                  <div class="tl diff-remove">- The next idea</div>
                  <div class="tl diff-add">+ YiTong</div>
                  <div class="tl diff-add">+ &#24322;&#21516;</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating icon -->
        <div class="icon-float">
          <img
            src="/images/prowl-icon.png"
            alt="Prowl App Icon"
            class="app-icon"
          />
        </div>

      </div>

      <!-- Paw prints between title and terminal -->
      <div class="paw-bridge">
        <svg
          class="paw p1"
          data-paw
          viewBox="0 0 20 20"
          fill="currentColor"
          role="button"
          tabindex="0"
          aria-label="Toggle bright paw"
        >
          <ellipse cx="6.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="13.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="3.2" cy="8.8" rx="1.7" ry="2.1" />
          <ellipse cx="16.8" cy="8.8" rx="1.7" ry="2.1" />
          <path d="M10 18.5c-3.2 0-5.8-2.2-5.8-4.5 0-2 1.6-3.5 3.2-3.5.9 0 1.4.6 2.6.6s1.7-.6 2.6-.6c1.6 0 3.2 1.5 3.2 3.5 0 2.3-2.6 4.5-5.8 4.5z" />
        </svg>
        <svg
          class="paw p2"
          data-paw
          viewBox="0 0 20 20"
          fill="currentColor"
          role="button"
          tabindex="0"
          aria-label="Toggle bright paw"
        >
          <ellipse cx="6.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="13.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="3.2" cy="8.8" rx="1.7" ry="2.1" />
          <ellipse cx="16.8" cy="8.8" rx="1.7" ry="2.1" />
          <path d="M10 18.5c-3.2 0-5.8-2.2-5.8-4.5 0-2 1.6-3.5 3.2-3.5.9 0 1.4.6 2.6.6s1.7-.6 2.6-.6c1.6 0 3.2 1.5 3.2 3.5 0 2.3-2.6 4.5-5.8 4.5z" />
        </svg>
        <svg
          class="paw p3"
          data-paw
          viewBox="0 0 20 20"
          fill="currentColor"
          role="button"
          tabindex="0"
          aria-label="Toggle bright paw"
        >
          <ellipse cx="6.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="13.5" cy="3.5" rx="2" ry="2.4" />
          <ellipse cx="3.2" cy="8.8" rx="1.7" ry="2.1" />
          <ellipse cx="16.8" cy="8.8" rx="1.7" ry="2.1" />
          <path d="M10 18.5c-3.2 0-5.8-2.2-5.8-4.5 0-2 1.6-3.5 3.2-3.5.9 0 1.4.6 2.6.6s1.7-.6 2.6-.6c1.6 0 3.2 1.5 3.2 3.5 0 2.3-2.6 4.5-5.8 4.5z" />
        </svg>
      </div>
    </div>

    <footer class="footer">
      <p>
        Built by <a
          href="https://github.com/onevcat"
          target="_blank"
          rel="noopener">@onevcat</a
        > with <span class="heart">&hearts;</span>
      </p>
    </footer>

  </main>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLElement>(".tab[data-tab]");
  const panels = document.querySelectorAll<HTMLElement>(".tab-panel[data-panel]");
  const canvasPanel = document.getElementById("canvas-panel")!;
  const canvasToggle = document.getElementById("canvas-toggle")!;
  const tabNames = ["prowl", "kingfisher", "meetcat", "yitong"];
  // Rotation: canvas → prowl → kingfisher → meetcat → yitong → canvas ...
  const sequence = ["canvas", ...tabNames];
  let seqIndex = sequence.indexOf("prowl");
  let timer: ReturnType<typeof setInterval>;
  const INTERVAL = 5000;

  function showTab(name: string) {
    canvasPanel.classList.remove("active");
    canvasToggle.classList.remove("active");
    tabs.forEach((t) => t.classList.toggle("active", t.dataset.tab === name));
    panels.forEach((p) => p.classList.toggle("active", p.dataset.panel === name));
  }

  function showCanvas() {
    panels.forEach((p) => p.classList.remove("active"));
    tabs.forEach((t) => t.classList.remove("active"));
    canvasPanel.classList.add("active");
    canvasToggle.classList.add("active");
  }

  function showByIndex(i: number) {
    const name = sequence[i];
    if (name === "canvas") {
      showCanvas();
    } else {
      showTab(name);
    }
  }

  function advance() {
    seqIndex = (seqIndex + 1) % sequence.length;
    showByIndex(seqIndex);
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(advance, INTERVAL);
  }

  function switchTo(name: string) {
    seqIndex = sequence.indexOf(name);
    showByIndex(seqIndex);
    resetTimer();
  }

  // Tab clicks
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => switchTo(tab.dataset.tab!));
  });

  // Canvas toggle
  canvasToggle.addEventListener("click", () => switchTo("canvas"));

  // Canvas card clicks → switch to that tab
  document.querySelectorAll<HTMLElement>(".canvas-card[data-card]").forEach((card) => {
    card.addEventListener("click", () => switchTo(card.dataset.card!));
  });

  // Action button flash
  document.querySelectorAll<HTMLElement>(".action-btn[data-run]").forEach((btn) => {
    btn.addEventListener("click", () => {
      btn.classList.add("flash");
      setTimeout(() => btn.classList.remove("flash"), 400);
    });
  });

  const brewCopyButton = document.getElementById("brew-copy") as HTMLButtonElement | null;
  const brewCommand = document.getElementById("brew-command")?.textContent?.trim();
  brewCopyButton?.addEventListener("click", async () => {
    if (!brewCommand || !brewCopyButton) return;

    try {
      await navigator.clipboard.writeText(brewCommand);
      brewCopyButton.textContent = "Copied!";
      brewCopyButton.classList.add("copied");
      window.setTimeout(() => {
        brewCopyButton.textContent = "Copy";
        brewCopyButton.classList.remove("copied");
      }, 1200);
    } catch (_error) {
      brewCopyButton.textContent = "Copy failed";
      window.setTimeout(() => {
        brewCopyButton.textContent = "Copy";
      }, 1200);
    }
  });

  const pawPrints = document.querySelectorAll<HTMLElement>(".paw[data-paw]");
  pawPrints.forEach((paw) => {
    paw.setAttribute("aria-pressed", "false");
  });

  function togglePaw(paw: HTMLElement) {
    const isLit = paw.classList.toggle("lit");
    paw.setAttribute("aria-pressed", String(isLit));
  }

  document.addEventListener("click", (event) => {
    const x = event.clientX;
    const y = event.clientY;
    for (const paw of pawPrints) {
      const rect = paw.getBoundingClientRect();
      if (x >= rect.left && x <= rect.right && y >= rect.top && y <= rect.bottom) {
        togglePaw(paw);
        break;
      }
    }
  });

  pawPrints.forEach((paw) => {
    paw.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        togglePaw(paw);
      }
    });
  });

  // Start auto-rotation
  resetTimer();
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 70% 50%, rgba(90, 228, 192, 0.04) 0%, transparent 60%),
      var(--bg-primary);
  }

  /* Layout: left text, right visual */
  .hero-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 3rem;
    align-items: center;
    max-width: 1080px;
    width: 100%;
    padding: 6rem 3rem 3rem;
  }

  /* ---- Left: text ---- */
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .title {
    font-family: var(--font-mono);
    font-size: 4.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .slogan {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.02em;
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    line-height: 1.4;
  }

  .subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 380px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .cta-group {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-mono);
    transition: all 0.15s;
    cursor: pointer;
    border: 1px solid transparent;
  }

  .btn-icon {
    width: 15px;
    height: 15px;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--bg-primary);
    border-color: var(--accent);
    border-radius: 6px;
  }

  .btn-primary:hover {
    opacity: 1;
    background: #6ef0cc;
    border-color: #6ef0cc;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(90, 228, 192, 0.25);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text-secondary);
    border-color: rgba(136, 153, 180, 0.25);
    border-radius: 6px;
  }

  .btn-secondary:hover {
    opacity: 1;
    color: var(--text-primary);
    border-color: rgba(136, 153, 180, 0.5);
    transform: translateY(-1px);
  }

  .brew-note {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0.3rem 0 1.5rem 0;
    line-height: 1.6;
  }

  .brew-command {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    background: rgba(90, 228, 192, 0.08);
    border-radius: 4px;
    padding: 0.08rem 0.35rem;
    margin-left: 0.2rem;
  }

  .brew-copy {
    margin-left: 0.45rem;
    padding: 0.08rem 0.35rem;
    border-radius: 4px;
    border: 1px solid rgba(136, 153, 180, 0.28);
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.65rem;
    font-family: var(--font-mono);
    cursor: pointer;
  }

  .brew-copy:hover {
    opacity: 1;
    border-color: rgba(136, 153, 180, 0.45);
  }

  .brew-copy.copied {
    color: var(--accent);
    border-color: rgba(90, 228, 192, 0.45);
    background: rgba(90, 228, 192, 0.12);
  }

  .fork-note {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .fork-note a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: rgba(136, 153, 180, 0.3);
    text-underline-offset: 2px;
  }

  .fork-note a:hover {
    color: var(--accent);
    opacity: 1;
  }

  /* ---- Right: visual ---- */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* App wireframe */
  .app-frame {
    width: 100%;
    max-width: 540px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(136, 153, 180, 0.12);
    background: #0a1018;
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(255, 255, 255, 0.03);
  }

  .frame-titlebar {
    display: flex;
    align-items: center;
    padding: 9px 14px;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .frame-dots {
    display: flex;
    gap: 6px;
  }

  .fdot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .fdot-r { background: #ff5f57; }
  .fdot-y { background: #febc2e; }
  .fdot-g { background: #28c840; }

  .frame-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-right: 28px;
  }

  .frame-content {
    display: flex;
    min-height: 300px;
  }

  /* Sidebar with vertical tabs */
  .frame-sidebar {
    width: 140px;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    padding: 6px 0;
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.015);
    flex-shrink: 0;
  }

  .tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 10px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-secondary);
    cursor: pointer;
    border-left: 2px solid transparent;
    transition: background 0.15s;
  }

  .tab.active {
    background: rgba(90, 228, 192, 0.06);
    color: var(--text-primary);
    border-left-color: var(--accent);
  }

  .tab.dim {
    color: var(--text-muted);
  }

  .tab-icon {
    font-size: 1rem;
    opacity: 0.5;
    line-height: 1;
  }

  .tab-label {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tab-badge {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .tab-badge.running {
    background: var(--accent);
  }

  .tab-badge.idle {
    background: var(--text-muted);
  }

  .sidebar-action {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    color: var(--text-muted);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .canvas-link {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-decoration: none;
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .canvas-link:hover {
    color: var(--accent);
    opacity: 1;
  }

  /* Main area */
  .frame-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    position: relative;
  }

  .frame-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    font-family: var(--font-mono);
    font-size: 0.6rem;
  }

  .toolbar-repo {
    color: var(--text-secondary);
    font-weight: 600;
  }

  .toolbar-actions {
    display: flex;
    gap: 6px;
  }

  .action-btn {
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(90, 228, 192, 0.08);
    color: var(--accent-dim);
    font-size: 0.58rem;
    border: 1px solid rgba(90, 228, 192, 0.12);
    cursor: pointer;
